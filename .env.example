# Bantu OS environment example
DEBUG=false
LOG_LEVEL=INFO

# LLM configuration
# Provider: "openai" or "openrouter"
DEFAULT_LLM_PROVIDER=openrouter
DEFAULT_LLM_MODEL=anthropic/claude-3.5-sonnet
LLM_API_KEY=
LLM_TEMPERATURE=0.7

# OpenRouter-specific (optional overrides)
# OPENROUTER_API_KEY=  # Set your OpenRouter key here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
