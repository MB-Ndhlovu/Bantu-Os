# Bantu-OS Linux Kernel Configuration
# Target: x86_64, minimal/embedded, no desktop bloat
# Based on Linux 6.x
# Usage: copy to .config at kernel source root, run make olddefconfig or make oldconfig

CONFIG_ARCH_X86_64=y
CONFIG_X86_64=y
CONFIG_64BIT=y

# Processor type
CONFIG_M586TSC=y
CONFIG_MATOM=y
CONFIG_MCORE2=y
CONFIG_GENERIC_CPU=y

# Minimal kernel image
CONFIG_VMLINUX_Z=y
CONFIG_PHYSICAL_START=0x1000000
CONFIG_PHYSICAL_ALIGN=0x200000

# Memory
CONFIG_NODES_SHIFT=1
CONFIG_MEMORY_SIZE=512
CONFIG_HIGHMEM64G=y
CONFIG_NEED_PER_CPU_EMBED_FIRST_CHUNK=y
CONFIG_KEXEC=y
CONFIG_KEXEC_FILE=y

# No modules (static build for embedded)
# CONFIG_MODULES is not set

# Boot
CONFIG_CMDLINE_BOOL=y
CONFIG_CMDLINE=""
CONFIG_CMDLINE_OVERRIDE=y
CONFIG_SCHED_SMT=y
CONFIG_NR_CPUS=4

# No initrd support needed (we build our own initramfs)
# CONFIG_BLK_DEV_INITRD is not set
CONFIG_INITRAMFS_SOURCE=""
# CONFIG_RD_GZIP is not set
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set

# CPU features
